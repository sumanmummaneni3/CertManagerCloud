# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=certguard
POSTGRES_USER=certguard_user
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=certguard_rmq
RABBITMQ_DEFAULT_PASS=change_me_to_a_strong_password
RABBITMQ_VHOST=/certguard

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 64 characters. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=replace-with-a-random-secret-that-is-at-least-64-characters-long!!

# ── Application ──────────────────────────────────────────────────────────────
# Set to false to enable Google OAuth2 login (required in production)
# Set to true to use the dev token bypass at POST /api/v1/auth/dev-token
APP_DEV_MODE=true

# Base URL of the application — used for OAuth2 redirect after login
# Change to your real domain in production (e.g. https://yourdomain.com)
APP_BASE_URL=https://localhost:58244

# ── SSL ──────────────────────────────────────────────────────────────────────
# Password for the PKCS12 keystore at /opt/certguard/certs/certguard.p12
SSL_KEYSTORE_PASSWORD=localdevpassword

# ── Google OAuth2 ────────────────────────────────────────────────────────────
# Only required when APP_DEV_MODE=false
# Create credentials at: https://console.cloud.google.com
#   → APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   → Application type: Web application
#   → Authorised redirect URI: https://<your-domain>/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Certificate Alerts ───────────────────────────────────────────────────────
# Number of days before expiry to flag a certificate as WARNING or CRITICAL
ALERT_THRESHOLD_WARNING_DAYS=30
ALERT_THRESHOLD_CRITICAL_DAYS=7

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme
